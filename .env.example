# Copy to .env.local for local or scheduled Oracle refresh.
# Never commit real credentials.
RATE_DB_USER=
RATE_DB_PASSWORD=

# Choose one DSN source:
# 1. Enter an explicit Oracle DSN, for example host.example.com:1521/service_name
# 2. Reuse DSN metadata from a saved DBeaver Oracle connection name.
RATE_DB_DSN=
RATE_DBEAVER_CONNECTION=

# Optional override when DBeaver uses a non-default workspace.
# RATE_DBEAVER_DATA_SOURCES=C:\Users\name\AppData\Roaming\DBeaverData\workspace6\General\.dbeaver\data-sources.json

# Optional Market Rate source overrides.
# Set Google Sheets/Drive URLs or file IDs when refreshing market guidelines.
# If omitted, the local sibling "organizing rate file" project settings are reused.
MARKET_RATE_SEA_URL=
MARKET_RATE_CNHK_URL=
# MARKET_RATE_SEA_FILE_ID=
# MARKET_RATE_CNHK_FILE_ID=
# MARKET_RATE_GDRIVE_CREDS_DIR=C:\Users\name\OneDrive\Documents\Claude\.gdrive-mcp
# ORGANIZING_RATE_DIR=C:\Users\name\OneDrive\Documents\Claude\organizing rate file

# Optional browser polling interval for an internal live static deployment.
# This is read when Vite starts or builds. Use 0 to disable automatic polling.
VITE_DATA_REFRESH_SECONDS=300

# Optional Google sign-in gate for web deployments.
# Create an OAuth 2.0 Web client in Google Cloud (consent screen = Internal),
# enable the Drive API, and add the deployed origin to Authorized JavaScript origins.
VITE_AUTH_REQUIRED=false
VITE_GOOGLE_CLIENT_ID=
VITE_ALLOWED_GOOGLE_DOMAINS=company.com

# When set, the dashboard reads its data from this restricted Google Drive file
# (shared to the company domain only) via the Drive API using the signed-in user's
# access token, instead of bundling a public weekly-monitoring.json. Leave blank to
# load the local public/data/weekly-monitoring.json (used for local development).
VITE_DRIVE_FILE_ID=
